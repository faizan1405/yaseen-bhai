# =============================================================================
# Asan Nikah — Environment Variables
# Copy to .env.local and fill in real values. NEVER commit .env.local (gitignored).
# =============================================================================

# --- Database (MongoDB Atlas) --------------------------------------------------
# Primary source of truth. Point at the production database, e.g. "asannikah".
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>/<database-name>?retryWrites=true&w=majority"

# Allow the bundled sample-profile / showcase fallback when the DB is unreachable
# or unseeded. MUST stay "false" in production so a real site never silently
# shows fake profiles — instead it surfaces a controlled empty/error state.
# In development this can be "true" so the UI is never blank.
ALLOW_DB_FALLBACK="false"

# --- Authentication (Auth.js / NextAuth v5, Google OAuth) ----------------------
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-32-character-random-auth-secret"
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# --- Public site URL (SEO metadata, sitemap, robots, canonical links) ----------
NEXT_PUBLIC_SITE_URL="https://asannikah.com"

# --- Cloud image storage (Vercel Blob) -----------------------------------------
# Required for profile-photo uploads. Uploads are rejected if this is unset/dummy.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# --- Email (Resend) ------------------------------------------------------------
# Leave RESEND_API_KEY blank to use safe mock emails (logged, never "sent", and
# never falsely reported as delivered to the user).
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# --- SMS ----------------------------------------------------------------------
# "REAL" enables a real provider (not yet implemented); anything else = mock SMS.
SMS_PROVIDER="MOCK"

# --- Payments (Razorpay) -------------------------------------------------------
# Use LIVE keys (rzp_live_...) in production. Test keys (rzp_test_...) are
# rejected in production by a server-side guard.
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# Webhook signing secret (Razorpay Dashboard > Webhooks). Required for the
# /api/payment/webhook server-to-server confirmation. Without it the webhook
# rejects all calls rather than trusting unsigned callbacks.
RAZORPAY_WEBHOOK_SECRET=""

# DEV-ONLY: charge a nominal ₹1 instead of the real package price so you can
# exercise the live checkout flow without moving real money. It is FORCE-DISABLED
# in production — even if left "true", production charges the real price and logs
# a warning — so the ₹1 test mode can never hit real customers. The real price
# ALWAYS comes from the server-side package catalogue; the browser never sets it.
RAZORPAY_TEST_MODE="false"

# --- AI Chatbot ----------------------------------------------------------------
# Leave AI_CHATBOT_API_KEY blank to use the offline fallback replies (clearly
# flagged isFallback:true, never presented as live AI answers).
AI_CHATBOT_API_KEY=""
AI_CHATBOT_PROVIDER="gemini"        # gemini | openai
AI_CHATBOT_MODEL="gemini-1.5-flash" # e.g. gemini-1.5-flash | gpt-4o-mini

# --- Notes ---------------------------------------------------------------------
# Public contact details (WhatsApp number, phone, email, address, social links)
# are NOT env vars — they are managed in the Admin > Settings panel and stored in
# the GlobalSettings collection, with bundled defaults in src/lib/businessLocation.ts.
