# Neon PostgreSQL Database Connection String (from Vercel Marketplace)
DATABASE_URL="postgresql://user:password@ep-dummy-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Auth.js / NextAuth configuration
