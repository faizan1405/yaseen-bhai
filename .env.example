# MongoDB Atlas Database Connection String
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>/<database-name>?retryWrites=true&w=majority"

# Allow demo-profile fallback when the DB is unreachable (off in production)
ALLOW_DB_FALLBACK="false"

# Auth.js / NextAuth configuration
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-32-character-random-auth-secret"

# Google OAuth Credentials
AUTH_GOOGLE_ID="your-google-oauth-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-oauth-client-secret"

# Public site URL (used for SEO metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL="https://rishteforever.in"

# Demo / Pricing & Access Simulator master switch ("true" | "false")
NEXT_PUBLIC_DEMO_MODE="true"

# Vercel Blob Storage Token (Private by default)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_dummytoken_12345"

# Email (Resend) — leave blank to use mock emails
RESEND_API_KEY=""
EMAIL_FROM="onboarding@resend.dev"

# SMS — "REAL" enables a real provider; anything else uses mock SMS
SMS_PROVIDER="MOCK"

# Payments (Razorpay) — keys containing "dummy" use Simulator payment mode
RAZORPAY_KEY_ID="rzp_dummy_key_id"
RAZORPAY_KEY_SECRET="rzp_dummy_key_secret"

# AI Chatbot Configuration
AI_CHATBOT_API_KEY=""
AI_CHATBOT_PROVIDER="gemini" # gemini | openai
AI_CHATBOT_MODEL="gemini-1.5-flash"
